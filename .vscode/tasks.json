{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build PE inspector",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe${fileDirname}\\main.exe",
                "${fileDirname}\\main.cpp",
                "${fileDirname}\\loader_core.cpp",
                "${fileDirname}\\loader32.cpp",
                "${fileDirname}\\loader64.cpp",
                "/link",
                "crypt32.lib",
                "/SUBSYSTEM:CONSOLE"
            ],
            "problemMatcher": [
                "$msCompile"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}